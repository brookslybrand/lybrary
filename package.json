{
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "remix build",
    "deploy": "fly deploy --remote-only",
    "dev": "remix dev",
    "start": "remix-serve build",
    "ts": "tsc",
    "clean": "rm -rf ./build ./public/build ./node_modules/.cache",
    "format": "prettier --write .",
    "lint": "eslint ./app --fix",
    "validate": "run-s lint format ts",
    "prisma:studio": "prisma studio",
    "setup": "npm run build && prisma generate && prisma migrate deploy && prisma db seed"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.15",
    "@heroicons/react": "^2.0.18",
    "@prisma/client": "^5.0.0",
    "@remix-run/css-bundle": "^1.18.1",
    "@remix-run/node": "^1.18.1",
    "@remix-run/react": "^1.18.1",
    "@remix-run/serve": "^1.18.1",
    "class-variance-authority": "^0.6.1",
    "isbot": "^3.6.8",
    "prisma": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "type-fest": "^3.13.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.18.1",
    "@remix-run/eslint-config": "^1.18.1",
    "@types/react": "^18.0.35",
    "@types/react-dom": "^18.0.11",
    "eslint": "^8.44.0",
    "execa": "^7.1.1",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.4.0",
    "tailwindcss": "^3.3.2",
    "tsx": "^3.12.7",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": "18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

{
  "name": "library",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "run-s build:*",
    "build:remix": "remix build --sourcemap",
    "build:server": "tsx ./other/build-server.ts",
    "deploy": "fly deploy --remote-only",
    "dev": "remix dev -c \"node ./server/dev-server.js\" --no-restart",
    "start": "cross-env NODE_ENV=production node .",
    "ts": "tsc",
    "clean": "rm -rf ./build ./public/build ./server-build ./node_modules/.cache",
    "format": "prettier --write .",
    "lint": "eslint ./app --fix",
    "validate": "run-s lint format ts",
    "prisma:studio": "prisma studio",
    "setup": "npm run build && prisma generate && prisma migrate deploy && prisma db seed"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.15",
    "@heroicons/react": "^2.0.18",
    "@prisma/client": "^5.0.0",
    "@remix-run/css-bundle": "^1.19.1",
    "@remix-run/express": "^1.19.1",
    "@remix-run/node": "^1.19.1",
    "@remix-run/react": "^1.19.1",
    "address": "^1.2.2",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "class-variance-authority": "^0.7.0",
    "close-with-grace": "^1.2.0",
    "compression": "^1.7.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "execa": "^7.1.1",
    "express": "^4.18.2",
    "get-port": "^7.0.0",
    "helmet": "^7.0.0",
    "isbot": "^3.6.13",
    "morgan": "^1.10.0",
    "prisma": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "type-fest": "^4.0.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.19.1",
    "@remix-run/eslint-config": "^1.19.1",
    "@types/compression": "^1.7.2",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^11.0.1",
    "@types/morgan": "^1.9.4",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "eslint": "^8.45.0",
    "fs-extra": "^11.1.1",
    "glob": "^10.3.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.4.1",
    "tailwindcss": "^3.3.3",
    "tsx": "^3.12.7",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": "18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
